# =============================================================================
# Message Watchdog — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for local development.
# NEVER commit .env to version control.
#
# In Azure (Container Instances), no .env file is used. The container reads
# all secrets from Azure Key Vault at startup using managed identity.
# Only AZURE_KEY_VAULT_URL is passed as an env var to the container.
# Run scripts/azure-setup.sh once to provision the vault and upload secrets.
# =============================================================================

# ---------------------------------------------------------------------------
# Azure Key Vault (optional for local dev — required in Azure)
# When set, secrets are loaded from Key Vault at startup.
# Leave unset locally to use the values in this file instead.
# ---------------------------------------------------------------------------
# AZURE_KEY_VAULT_URL=https://watchdog-kv.vault.azure.net/

# ---------------------------------------------------------------------------
# Telegram API  (always required)
# Get api_id and api_hash from: https://my.telegram.org/apps
# Log in → "API development tools" → create an app (any name is fine).
# ---------------------------------------------------------------------------
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_string_here
TELEGRAM_PHONE=+1XXXXXXXXXX           # E.164 format, e.g. +19175551234

# ---------------------------------------------------------------------------
# LLM Provider — choose ONE section below based on llm.provider in config.yaml
# ---------------------------------------------------------------------------

# --- Option A: Anthropic Claude (default) ---
# Get key from: https://console.anthropic.com
# Cost: ~$0.001/day at typical usage with surge gate enabled
ANTHROPIC_API_KEY=sk-ant-api03-...

# --- Option B: Azure OpenAI Service or Azure AI Foundry ---
# These are charged against your Azure subscription / dev credits.
# Deploy a model in Azure Portal → Azure OpenAI → Deployments
# OR Azure Portal → Azure AI Foundry → Models + endpoints → Serverless API
#
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=your_azure_openai_key_here

# ---------------------------------------------------------------------------
# Twilio — phone call alerts (rings through silent mode)
# ---------------------------------------------------------------------------
# Free trial at: https://console.twilio.com — gives $15 credit (~1,000+ calls to US numbers)
# After trial: ~$0.013/minute to US numbers (~$0.007 per 30-second alert call)
# For a personal watchdog (a few calls/week): expect < $0.50/month after trial expires
#
# To get DND bypass on iOS:  Settings → Focus → DND → Allow Calls From → add "H1B Alert"
# To get DND bypass on Android: DND Settings → Exceptions → allow contact "H1B Alert"
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1XXXXXXXXXX       # Twilio number from console
TWILIO_TO_NUMBER=+1XXXXXXXXXX         # Your US mobile number

# ---------------------------------------------------------------------------
# Gmail App Password — email alerts
# ---------------------------------------------------------------------------
# Generate at: https://myaccount.google.com/apppasswords
# Requires 2-Step Verification. Do NOT use your normal Gmail password.
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
